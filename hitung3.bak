#!/usr/bin/env python3
"""
Hisab Awal Bulan Hijriyah (MABIMS + Yallop + Odeh)
Versi final dengan:
- Multi-lokasi 14 titik strategis Indonesia
- Azimuth bulan, lag time, moonset (setelah maghrib)
- Yallop & Odeh untuk Jakarta
- Grid scan menggunakan maghrib lokal per titik
- Output UTC (universal)
"""

import numpy as np
from skyfield.api import load, wgs84
from skyfield import almanac
from datetime import datetime, timedelta, timezone
import pytz
from hijridate import Hijri
import sys
import traceback

# ===================================================================
# Konfigurasi
# ===================================================================
LATITUDE = -6.2088
LONGITUDE = 106.8456
ELEVATION = 8.0
TEMPERATURE_C = 25.0
PRESSURE_MBAR = 1010.0
TZ_WIB = pytz.timezone('Asia/Jakarta')

# Ephemeris
EPH_FILE = 'de440.bsp'
try:
    ts = load.timescale()
    eph = load(EPH_FILE)
    print(f"✅ Menggunakan ephemeris {EPH_FILE}")
except Exception:
    print(f"⚠️  {EPH_FILE} tidak ditemukan, fallback ke de421.bsp")
    eph = load('de421.bsp')

# ===================================================================
# Daftar lokasi representatif Indonesia (14 titik)
# ===================================================================
LOKASI_INDONESIA = [
    ("Sabang (Aceh)", 5.8943, 95.3184, 15),
    ("Medan", 3.5952, 98.6722, 25),
    ("Padang", -0.9471, 100.4172, 10),
    ("Jakarta", -6.2088, 106.8456, 8),
    ("Bandung", -6.9175, 107.6191, 10),
    ("Surabaya", -7.2575, 112.7521, 5),
    ("Banjarmasin", -3.3194, 114.5928, 10),
    ("Balikpapan", -1.2379, 116.8529, 10),
    ("Makassar", -5.1477, 119.4327, 10),
    ("Manado", 1.4748, 124.8421, 10),
    ("Kupang", -10.1772, 123.6070, 10),
    ("Ambon", -3.6550, 128.1908, 10),
    ("Jayapura", -2.5337, 140.7181, 10),
]

MARGIN_ELONGASI = 0.05

# ===================================================================
# Fungsi bantu
# ===================================================================
def to_utc_naive(dt):
    if dt.tzinfo is None:
        return dt
    return dt.astimezone(timezone.utc).replace(tzinfo=None)

def delta_t_approx(year):
    y = year + 0.5
    if 2005 <= y <= 2050:
        t = y - 2000
        dt = 62.92 + 0.32217 * t + 0.005589 * t**2
    elif 1986 <= y < 2005:
        t = y - 2000
        dt = 63.86 + 0.3345 * t - 0.060374 * t**2 + 0.0017275 * t**3
    else:
        t = (y - 2000) / 100
        dt = 64 + 59 * t
    return dt

# ===================================================================
# Pencarian waktu matahari terbenam & bulan terbenam (setelah maghrib)
# ===================================================================
def cari_waktu_maghrib(tanggal, ts, eph, topos):
    t0 = ts.utc(tanggal.year, tanggal.month, tanggal.day, 0)
    t1 = ts.utc(tanggal.year, tanggal.month, tanggal.day, 23, 59)
    f = almanac.sunrise_sunset(eph, topos)
    times, events = almanac.find_discrete(t0, t1, f)
    sunset_times = [t for t, e in zip(times, events) if not e]
    return sunset_times[0].utc_datetime() if sunset_times else None

def cari_waktu_moonset_after_maghrib(maghrib_utc, ts, eph, topos):
    """
    Mencari moonset setelah maghrib (dalam rentang 12 jam setelah maghrib).
    """
    if maghrib_utc is None:
        return None
    t0 = ts.from_datetime(maghrib_utc)
    t1 = ts.from_datetime(maghrib_utc + timedelta(hours=12))
    f = almanac.risings_and_settings(eph, eph['moon'], topos)
    times, events = almanac.find_discrete(t0, t1, f)
    moonsets = [t for t, e in zip(times, events) if not e]
    return moonsets[0].utc_datetime() if moonsets else None

def cari_best_time(maghrib_utc, moonset_utc):
    if moonset_utc is None:
        return None
    lag = (moonset_utc - maghrib_utc).total_seconds() / 3600
    if lag <= 0:
        return None
    offset_hours = lag * (4 / 9)
    best = maghrib_utc + timedelta(hours=offset_hours)
    return best

# ===================================================================
# Fungsi perhitungan posisi (toposentrik + geosentris + azimuth)
# ===================================================================
def hitung_bulan_pada_waktu(waktu_utc, ts, eph, lokasi_geo):
    detik = waktu_utc.second + waktu_utc.microsecond / 1e6
    t = ts.utc(waktu_utc.year, waktu_utc.month, waktu_utc.day,
               waktu_utc.hour, waktu_utc.minute, detik)

    posisi = lokasi_geo.at(t)
    bulan_top = posisi.observe(eph['moon']).apparent()
    matahari_top = posisi.observe(eph['sun']).apparent()

    # Dengan refraksi + azimuth
    alt_bulan_ref, az_bulan_ref, _ = bulan_top.altaz(temperature_C=TEMPERATURE_C, pressure_mbar=PRESSURE_MBAR)
    alt_matahari_ref, _, _ = matahari_top.altaz(temperature_C=TEMPERATURE_C, pressure_mbar=PRESSURE_MBAR)

    # Tanpa refraksi (airless) untuk Yallop/Odeh
    alt_bulan_airless, _, _ = bulan_top.altaz()
    alt_matahari_airless, _, _ = matahari_top.altaz()

    elong_top = bulan_top.separation_from(matahari_top).degrees

    # Geosentris (untuk MABIMS)
    earth = eph['earth']
    bulan_geo = earth.at(t).observe(eph['moon']).apparent()
    matahari_geo = earth.at(t).observe(eph['sun']).apparent()
    elong_geo = bulan_geo.separation_from(matahari_geo).degrees

    jarak_bulan = bulan_top.distance().km

    return (alt_bulan_ref.degrees, az_bulan_ref.degrees,
            alt_matahari_ref.degrees,
            alt_bulan_airless.degrees, alt_matahari_airless.degrees,
            elong_top, jarak_bulan, elong_geo)

# ===================================================================
# Illumination, probabilitas, kontras
# ===================================================================
def hitung_illumination_fraction(waktu_utc, ts, eph):
    detik = waktu_utc.second + waktu_utc.microsecond / 1e6
    t = ts.utc(waktu_utc.year, waktu_utc.month, waktu_utc.day,
               waktu_utc.hour, waktu_utc.minute, detik)
    earth = eph['earth']
    moon = earth.at(t).observe(eph['moon']).apparent()
    sun = earth.at(t).observe(eph['sun']).apparent()
    phase_angle = moon.separation_from(sun).radians
    k = (1 + np.cos(phase_angle)) / 2
    return k * 100

def probabilitas_hilal(v):
    k = 2.0
    p = 1 / (1 + np.exp(-k * v))
    return p * 100

def hitung_kontras_hilal(arcv_deg, elong_deg, width_menit):
    B_moon = width_menit * (elong_deg / 10)
    B_sky = np.exp(-0.25 * arcv_deg)
    if B_sky <= 0:
        return 0
    contrast = B_moon / (B_sky * 100)
    return contrast

# ===================================================================
# Scan visibilitas Indonesia (grid kasar) dengan maghrib lokal per titik
# ===================================================================
def scan_visibilitas_indonesia(tanggal, ts, eph):
    """
    Membuat peta kasar visibilitas hilal Indonesia.
    Setiap titik grid dievaluasi pada waktu maghrib lokalnya sendiri.
    """
    print("\n=== SCAN VISIBILITAS INDONESIA (grid kasar) ===")
    earth = eph['earth']
    latitudes = np.arange(-10, 7, 4)     # dari selatan ke utara
    longitudes = np.arange(95, 141, 6)   # dari barat ke timur

    visible_points = []

    for lat in latitudes:
        for lon in longitudes:
            topos = wgs84.latlon(lat, lon)
            lokasi = earth + topos

            # Cari maghrib lokal untuk titik ini
            lokal_maghrib = cari_waktu_maghrib(tanggal, ts, eph, topos)
            if not lokal_maghrib:
                continue

            # Hitung parameter pada waktu maghrib lokal
            (_, _, _, alt_bulan_air, alt_matahari_air,
             elong_top, jarak_bulan, _) = hitung_bulan_pada_waktu(lokal_maghrib, ts, eph, lokasi)

            arcv = alt_bulan_air - alt_matahari_air
            sd_rad = np.arcsin(1737.4 / jarak_bulan)
            width = sd_rad * (1 - np.cos(np.radians(elong_top)))
            width = width * (180 / np.pi) * 60
            a = 11.8371 - 6.3226 * width + 0.7319 * width**2 - 0.1018 * width**3
            q = (arcv - a) / 10

            if q > -0.232:  # minimal kelas D Yallop
                visible_points.append((lat, lon))

    if visible_points:
        print(f"Wilayah potensial rukyat: {len(visible_points)} titik grid")
        for lat, lon in visible_points[:15]:
            print(f"  lat={lat:.1f}, lon={lon:.1f}")
    else:
        print("Tidak ada wilayah Indonesia dengan kemungkinan rukyat")

# ===================================================================
# New moon
# ===================================================================
def cari_new_moon_terdekat(tanggal_acuan, ts, eph, rentang_hari=20):
    t_start = tanggal_acuan - timedelta(days=rentang_hari)
    t_end = tanggal_acuan + timedelta(days=rentang_hari)
    t0 = ts.utc(t_start.year, t_start.month, t_start.day, 0)
    t1 = ts.utc(t_end.year, t_end.month, t_end.day, 23, 59)
    print(f"Mencari new moon antara {t0.utc_datetime()} dan {t1.utc_datetime()}")
    f = almanac.moon_phases(eph)
    times, phases = almanac.find_discrete(t0, t1, f)
    new_moon_times = [t for t, p in zip(times, phases) if p == 0]
    print(f"Ditemukan {len(new_moon_times)} new moon")
    if not new_moon_times:
        return None, None
    new_moon_utc = [t.utc_datetime() for t in new_moon_times]
    acuan_wib = TZ_WIB.localize(datetime.combine(tanggal_acuan, datetime.min.time()))
    acuan_utc = acuan_wib.astimezone(timezone.utc)
    terdekat_utc = min(new_moon_utc, key=lambda d: abs((d - acuan_utc).total_seconds()))
    terdekat_wib = terdekat_utc.astimezone(TZ_WIB)
    tanggal_lokal_newmoon = terdekat_wib.date()
    return terdekat_utc, tanggal_lokal_newmoon

# ===================================================================
# Klasifikasi Yallop & Odeh
# ===================================================================
def yallop_class(q):
    if q > 0.216:
        return "A — mudah terlihat mata telanjang"
    elif q > -0.014:
        return "B — terlihat kondisi sempurna"
    elif q > -0.160:
        return "C — perlu alat bantu, bisa naked eye jika ditemukan"
    elif q > -0.232:
        return "D — perlu alat bantu optik"
    else:
        return "E — tidak terlihat walau dengan teleskop"

def odeh_class(v):
    if v >= 5.65:
        return "A — Mudah terlihat (mata telanjang)"
    elif v >= 2.0:
        return "B — Terlihat dengan alat bantu (bisa naked eye)"
    elif v >= -0.96:
        return "C — Hanya terlihat dengan alat bantu optik/teleskop"
    else:
        return "D — Tidak terlihat"

# ===================================================================
# Kriteria MABIMS historis dengan toleransi
# ===================================================================
def cek_mabims_historis(tanggal, alt_bulan, elong_geosentris, umur_jam, EPS=1e-6):
    if tanggal.year >= 2022:
        alt_ok = (alt_bulan + EPS) >= 3.0
        elong_ok = (elong_geosentris + EPS) >= 6.4
        if not elong_ok and (6.4 - elong_geosentris) <= MARGIN_ELONGASI:
            elong_ok = True
            print(f"      ⚠️  Elongasi borderline ({elong_geosentris:.2f}°, dalam margin {MARGIN_ELONGASI:.2f}°)")
        terpenuhi = alt_ok and elong_ok
        label = "Neo MABIMS (2022+)"
        umur_ok = True
    else:
        alt_ok = (alt_bulan + EPS) >= 2.0
        elong_ok = (elong_geosentris + EPS) >= 3.0
        if not elong_ok and (3.0 - elong_geosentris) <= MARGIN_ELONGASI:
            elong_ok = True
            print(f"      ⚠️  Elongasi borderline ({elong_geosentris:.2f}°, dalam margin {MARGIN_ELONGASI:.2f}°)")
        umur_ok = (umur_jam + EPS) >= 8.0
        terpenuhi = (alt_ok and elong_ok) or (umur_ok and alt_ok)
        label = "MABIMS Lama (pre-2022)"
    return terpenuhi, alt_ok, elong_ok, umur_ok, label

# ===================================================================
# Cek satu lokasi (untuk multi-lokasi)
# ===================================================================
def cek_mabims_lokasi(tanggal, nm_utc, lokasi_info, ts, eph, EPS=1e-6):
    nama, lat, lon, elev = lokasi_info
    topos = wgs84.latlon(lat, lon, elevation_m=elev)
    lokasi_geo = eph['earth'] + topos

    maghrib_utc = cari_waktu_maghrib(tanggal, ts, eph, topos)
    if maghrib_utc is None:
        return None

    moonset_utc = cari_waktu_moonset_after_maghrib(maghrib_utc, ts, eph, topos)
    if moonset_utc is None:
        return None

    (alt_bulan_ref, az_bulan_ref,
     alt_matahari_ref,
     _, _,
     elong_top, jarak_bulan, elong_geo) = hitung_bulan_pada_waktu(maghrib_utc, ts, eph, lokasi_geo)

    lag_menit = (moonset_utc - maghrib_utc).total_seconds() / 60

    maghrib_naive = to_utc_naive(maghrib_utc)
    nm_naive = to_utc_naive(nm_utc)
    umur_jam = (maghrib_naive - nm_naive).total_seconds() / 3600
    if umur_jam < 0:
        return None

    mabims_ok, alt_ok, elong_ok, umur_ok, _ = cek_mabims_historis(tanggal, alt_bulan_ref, elong_geo, umur_jam, EPS)
    if mabims_ok:
        return {
            'nama': nama,
            'alt': alt_bulan_ref,
            'az': az_bulan_ref,
            'elong': elong_geo,
            'umur': umur_jam,
            'maghrib': maghrib_utc,
            'moonset': moonset_utc,
            'lag_menit': lag_menit,
        }
    return None

# ===================================================================
# Fungsi utama hitung awal bulan
# ===================================================================
def hitung_awal_bulan_hijriah(tahun_hijriah, bulan_hijriah, ts, eph, topos_jakarta, lokasi_geo_jakarta):
    hijri_date = Hijri(tahun_hijriah, bulan_hijriah, 1)
    gregorian = hijri_date.to_gregorian()
    perkiraan = datetime(gregorian.year, gregorian.month, gregorian.day).date()
    print(f"Perkiraan awal bulan {tahun_hijriah}-{bulan_hijriah}: {perkiraan}")

    nm_utc, tgl_lokal_newmoon = cari_new_moon_terdekat(perkiraan, ts, eph)
    if nm_utc is None:
        raise RuntimeError(f"Tidak ditemukan new moon untuk {tahun_hijriah}-{bulan_hijriah}")
    nm_wib = nm_utc.astimezone(TZ_WIB)
    print(f"Ijtimak: {nm_wib.strftime('%d-%m-%Y %H:%M WIB')}, tanggal lokal: {tgl_lokal_newmoon}")

    maghrib_nm = cari_waktu_maghrib(tgl_lokal_newmoon, ts, eph, topos_jakarta)
    nm_naive = to_utc_naive(nm_utc)
    if maghrib_nm is not None and nm_naive < to_utc_naive(maghrib_nm):
        start_i = 0
        print("  ℹ️  Ijtimak sebelum maghrib → pengecekan dimulai hari yang sama")
    else:
        start_i = 1
        print("  ℹ️  Ijtimak setelah maghrib → pengecekan dimulai besok")

    EPS = 1e-6
    for i in range(start_i, start_i + 3):
        tanggal_periksa = tgl_lokal_newmoon + timedelta(days=i)
        print(f"\nMemeriksa maghrib tanggal {tanggal_periksa}")

        # --- Hitung Jakarta (dengan Yallop/Odeh) ---
        maghrib_utc = cari_waktu_maghrib(tanggal_periksa, ts, eph, topos_jakarta)
        if maghrib_utc is None:
            print("  [Jakarta] Tidak ada maghrib?")
        else:
            maghrib_wib = maghrib_utc.astimezone(TZ_WIB)
            print(f"  [Jakarta] Maghrib: {maghrib_wib.strftime('%H:%M WIB')} ({maghrib_utc.strftime('%H:%M UTC')})")

            (alt_bulan_ref_m, _, alt_matahari_ref_m,
             alt_bulan_air_m, alt_matahari_air_m,
             elong_top_m, _, elong_geo_m) = hitung_bulan_pada_waktu(maghrib_utc, ts, eph, lokasi_geo_jakarta)

            maghrib_naive = to_utc_naive(maghrib_utc)
            nm_naive = to_utc_naive(nm_utc)
            umur_jam = (maghrib_naive - nm_naive).total_seconds() / 3600
            if umur_jam < 0:
                print("  [Jakarta] ❌ Umur bulan negatif")
            else:
                mabims_ok_jakarta, alt_ok, elong_ok, umur_ok, label_mabims = cek_mabims_historis(
                    tanggal_periksa, alt_bulan_ref_m, elong_geo_m, umur_jam, EPS
                )
                print(f"  [MABIMS Jakarta] {label_mabims}: alt={alt_bulan_ref_m:.2f}° ({'✓' if alt_ok else '✗'}), "
                      f"elong_geo={elong_geo_m:.2f}° ({'✓' if elong_ok else '✗'}), "
                      f"umur={umur_jam:.1f} jam ({'✓' if umur_ok else '✗'}) -> {'✅ Lolos' if mabims_ok_jakarta else '❌ Gagal'}")

                # --- Yallop & Odeh untuk Jakarta (best time) ---
                moonset_utc = cari_waktu_moonset_after_maghrib(maghrib_utc, ts, eph, topos_jakarta)
                if moonset_utc:
                    best_utc = cari_best_time(maghrib_utc, moonset_utc)
                    if best_utc:
                        (_, _, _, alt_bulan_air_b, alt_matahari_air_b,
                         elong_top_b, jarak_bulan, _) = hitung_bulan_pada_waktu(best_utc, ts, eph, lokasi_geo_jakarta)
                        arcv_deg = alt_bulan_air_b - alt_matahari_air_b
                        sd_rad = np.arcsin(1737.4 / jarak_bulan)
                        width_rad = sd_rad * (1 - np.cos(np.radians(elong_top_b)))
                        width_rad = max(0.0, width_rad)
                        width_menit = width_rad * (180 / np.pi) * 60
                        illum = hitung_illumination_fraction(best_utc, ts, eph)

                        print(f"  [VISIBILITAS Jakarta] Altitude bulan (airless): {alt_bulan_air_b:.2f}°, Matahari: {alt_matahari_air_b:.2f}°")
                        print(f"    Elongasi (toposentrik): {elong_top_b:.2f}°, ARCV (airless): {arcv_deg:.2f}°")
                        print(f"    Lebar sabit: {width_menit:.2f} menit busur, Illumination: {illum:.2f}%")

                        W = width_menit
                        a = 11.8371 - 6.3226 * W + 0.7319 * W**2 - 0.1018 * W**3
                        q_yallop = (arcv_deg - a) / 10
                        yallop_klas = yallop_class(q_yallop)
                        print(f"    Yallop q = {q_yallop:.2f} -> {yallop_klas}")

                        f_odeh = -0.1018 * W**3 + 0.7319 * W**2 - 6.3226 * W + 7.1651
                        v_odeh = arcv_deg - f_odeh
                        odeh_klas = odeh_class(v_odeh)
                        print(f"    Odeh V = {v_odeh:.2f} -> {odeh_klas}")

                        prob = probabilitas_hilal(v_odeh)
                        print(f"    Probabilitas terlihat: {prob:.1f}%")

                        contrast = hitung_kontras_hilal(arcv_deg, elong_top_b, width_menit)
                        print(f"    Kontras hilal vs langit: {contrast:.4f}")
                        if contrast > 0.15:
                            print("      → Hilal sangat mudah terlihat")
                        elif contrast > 0.05:
                            print("      → Hilal kemungkinan terlihat")
                        elif contrast > 0.01:
                            print("      → Hilal sangat sulit terlihat")
                        else:
                            print("      → Hilal hampir mustahil terlihat")

        # --- Evaluasi multi-lokasi (seluruh Indonesia) ---
        lokasi_lolos = []
        for lokasi in LOKASI_INDONESIA:
            res = cek_mabims_lokasi(tanggal_periksa, nm_utc, lokasi, ts, eph, EPS)
            if res:
                lokasi_lolos.append(res)

        if lokasi_lolos:
            print(f"\n  🌏 LOKASI YANG MEMENUHI MABIMS NASIONAL ({len(lokasi_lolos)} titik):")
            for item in lokasi_lolos:
                maghrib_utc = item['maghrib']
                moonset_utc = item['moonset']
                print(f"     - {item['nama']}: alt={item['alt']:.2f}°, az={item['az']:.1f}°, "
                      f"elong={item['elong']:.2f}°, umur={item['umur']:.1f} jam, "
                      f"lag={item['lag_menit']:.0f} menit, maghrib={maghrib_utc.strftime('%H:%M')} UTC, "
                      f"moonset={moonset_utc.strftime('%H:%M')} UTC")

            tanggal_1 = tanggal_periksa + timedelta(days=1)
            print(f"\n  ✅ Berdasarkan hisab multi-lokasi, awal bulan = {tanggal_1}")
            scan_visibilitas_indonesia(tanggal_periksa, ts, eph)  # tanpa maghrib_utc
            return tanggal_1
        else:
            print("\n  ❌ Tidak ada lokasi di Indonesia yang memenuhi MABIMS")

    # Istikmal
    tanggal_istikmal = tgl_lokal_newmoon + timedelta(days=start_i + 3)
    print(f"\n⚠️  MABIMS tidak terpenuhi di seluruh Indonesia dalam 3 hari berturut-turut → Istikmal")
    print(f"   Awal bulan (istikmal) = {tanggal_istikmal}")
    return tanggal_istikmal

# ===================================================================
# Main
# ===================================================================
def main():
    try:
        tahun = int(input("Masukkan tahun Hijriah (contoh: 1445): "))
    except ValueError:
        print("Tahun harus berupa angka.")
        return

    tahun_masehi = Hijri(tahun, 1, 1).to_gregorian().year
    dt = delta_t_approx(tahun_masehi)
    print(f"Delta-T (perkiraan): {dt:.1f} detik")

    earth = eph['earth']
    topos_jakarta = wgs84.latlon(LATITUDE, LONGITUDE, elevation_m=ELEVATION)
    lokasi_geo_jakarta = earth + topos_jakarta
    print(f"Lokasi referensi: Jakarta ({LATITUDE}°S, {LONGITUDE}°E, elevasi {ELEVATION} m)")
    print(f"Atmosfer: T={TEMPERATURE_C}°C, P={PRESSURE_MBAR} mbar")
    print(f"Evaluasi MABIMS dilakukan di {len(LOKASI_INDONESIA)} titik representatif Indonesia.")
    print("Keputusan awal bulan diambil jika minimal SATU lokasi memenuhi kriteria MABIMS.")
    print(f"Toleransi elongasi: {MARGIN_ELONGASI:.2f}° untuk mengakomodasi perbedaan ephemeris.\n")

    try:
        ramadan = hitung_awal_bulan_hijriah(tahun, 9, ts, eph, topos_jakarta, lokasi_geo_jakarta)
        syawal = hitung_awal_bulan_hijriah(tahun, 10, ts, eph, topos_jakarta, lokasi_geo_jakarta)
        print(f"\n=== HASIL AKHIR ===")
        print(f"1 Ramadan {tahun} H (MABIMS Indonesia): {ramadan}")
        print(f"1 Syawal  {tahun} H (MABIMS Indonesia): {syawal}")
        print("\nCatatan: Hasil ini adalah simulasi hisab astronomi multi-lokasi. Keputusan resmi mengikuti Sidang Isbat Kemenag RI.")
    except Exception as e:
        print(f"Terjadi kesalahan: {e}")
        traceback.print_exc()

if __name__ == "__main__":
    main()
