#!/usr/bin/env python3
"""
Hisab Awal Bulan Hijriyah (MABIMS + Yallop + Odeh)

Versi final dengan perbaikan:
- Pemisahan altitude refraksi (MABIMS) dan airless (ARCV Yallop/Odeh)
- Best time menggunakan faktor 4/9 lag time
- Koreksi konstanta Odeh (7.1651) dan threshold klasifikasi (-0.96)
- Moonset range diperluas hingga +1 hari
- Semi-diameter bulan menggunakan arcsin
- Perbaikan kritis: elongasi geosentris dihitung dari pusat Bumi
"""

import numpy as np
from skyfield.api import load, wgs84
from skyfield import almanac
from datetime import datetime, timedelta, timezone
import pytz
from hijridate import Hijri
import traceback


# ==========================================================
# KONFIGURASI LOKASI
# ==========================================================

LATITUDE = -6.2088
LONGITUDE = 106.8456
ELEVATION = 8.0

TEMPERATURE_C = 25.0
PRESSURE_MBAR = 1010.0

TZ_WIB = pytz.timezone("Asia/Jakarta")


# ==========================================================
# EPHEMERIS
# ==========================================================

EPH_FILE = "de440.bsp"

try:
    ts = load.timescale()
    eph = load(EPH_FILE)
    print(f"✅ Menggunakan ephemeris {EPH_FILE}")
except Exception:
    print(f"⚠️ {EPH_FILE} tidak ditemukan, fallback ke de421.bsp")
    eph = load("de421.bsp")


# ==========================================================
# UTILITAS TIMEZONE
# ==========================================================

def to_utc_naive(dt):
    if dt.tzinfo is None:
        return dt
    return dt.astimezone(timezone.utc).replace(tzinfo=None)


# ==========================================================
# PENCARIAN MAGHRIB
# ==========================================================

def cari_waktu_maghrib(tanggal, ts, eph, topos):

    t0 = ts.utc(tanggal.year, tanggal.month, tanggal.day, 0)
    t1 = ts.utc(tanggal.year, tanggal.month, tanggal.day, 23, 59)

    f = almanac.sunrise_sunset(eph, topos)

    times, events = almanac.find_discrete(t0, t1, f)

    sunset_times = [
        t for t, e in zip(times, events) if not e
    ]

    if sunset_times:
        return sunset_times[0].utc_datetime()

    return None


# ==========================================================
# PENCARIAN MOONSET
# ==========================================================

def cari_waktu_moonset(tanggal, ts, eph, topos):

    t0 = ts.utc(tanggal.year, tanggal.month, tanggal.day, 0)
    t1 = ts.utc(tanggal.year, tanggal.month, tanggal.day, 36)

    f = almanac.risings_and_settings(eph, eph["moon"], topos)

    times, events = almanac.find_discrete(t0, t1, f)

    moonset_times = [
        t for t, e in zip(times, events) if not e
    ]

    if moonset_times:
        return moonset_times[0].utc_datetime()

    return None


# ==========================================================
# BEST TIME OBSERVASI
# ==========================================================

def cari_best_time(maghrib_utc, moonset_utc):

    if moonset_utc is None:
        return None

    lag = (moonset_utc - maghrib_utc).total_seconds() / 3600

    if lag <= 0:
        return None

    offset_hours = lag * (4 / 9)

    best = maghrib_utc + timedelta(hours=offset_hours)

    return best


# ==========================================================
# POSISI BULAN
# ==========================================================

def hitung_bulan_pada_waktu(waktu_utc, ts, eph, lokasi_geo):

    detik = waktu_utc.second + waktu_utc.microsecond / 1e6

    t = ts.utc(
        waktu_utc.year,
        waktu_utc.month,
        waktu_utc.day,
        waktu_utc.hour,
        waktu_utc.minute,
        detik,
    )

    posisi = lokasi_geo.at(t)

    bulan_top = posisi.observe(eph["moon"]).apparent()
    matahari_top = posisi.observe(eph["sun"]).apparent()

    alt_bulan_ref, _, _ = bulan_top.altaz(
        temperature_C=TEMPERATURE_C,
        pressure_mbar=PRESSURE_MBAR,
    )

    alt_matahari_ref, _, _ = matahari_top.altaz(
        temperature_C=TEMPERATURE_C,
        pressure_mbar=PRESSURE_MBAR,
    )

    alt_bulan_airless, _, _ = bulan_top.altaz()
    alt_matahari_airless, _, _ = matahari_top.altaz()

    elong_top = bulan_top.separation_from(matahari_top).degrees

    earth = eph["earth"]

    bulan_geo = earth.at(t).observe(eph["moon"]).apparent()
    matahari_geo = earth.at(t).observe(eph["sun"]).apparent()

    elong_geo = bulan_geo.separation_from(matahari_geo).degrees

    jarak_bulan = bulan_top.distance().km

    return (
        alt_bulan_ref.degrees,
        alt_matahari_ref.degrees,
        alt_bulan_airless.degrees,
        alt_matahari_airless.degrees,
        elong_top,
        jarak_bulan,
        elong_geo,
    )


# ==========================================================
# PENCARIAN NEW MOON
# ==========================================================

def cari_new_moon_terdekat(tanggal_acuan, ts, eph, rentang_hari=20):

    t_start = tanggal_acuan - timedelta(days=rentang_hari)
    t_end = tanggal_acuan + timedelta(days=rentang_hari)

    t0 = ts.utc(t_start.year, t_start.month, t_start.day, 0)
    t1 = ts.utc(t_end.year, t_end.month, t_end.day, 23, 59)

    print(f"Mencari new moon antara {t0.utc_datetime()} dan {t1.utc_datetime()}")

    f = almanac.moon_phases(eph)

    times, phases = almanac.find_discrete(t0, t1, f)

    new_moon_times = [
        t for t, p in zip(times, phases) if p == 0
    ]

    print(f"Ditemukan {len(new_moon_times)} new moon")

    if not new_moon_times:
        return None, None

    new_moon_utc = [t.utc_datetime() for t in new_moon_times]

    acuan_wib = TZ_WIB.localize(
        datetime.combine(tanggal_acuan, datetime.min.time())
    )

    acuan_utc = acuan_wib.astimezone(timezone.utc)

    terdekat_utc = min(
        new_moon_utc,
        key=lambda d: abs((d - acuan_utc).total_seconds()),
    )

    terdekat_wib = terdekat_utc.astimezone(TZ_WIB)

    return terdekat_utc, terdekat_wib.date()


# ==========================================================
# KLASIFIKASI YALLOP
# ==========================================================

def yallop_class(q):

    if q > 0.216:
        return "A — mudah terlihat mata telanjang"

    elif q > -0.014:
        return "B — terlihat kondisi sempurna"

    elif q > -0.160:
        return "C — perlu alat bantu"

    elif q > -0.232:
        return "D — perlu teleskop"

    else:
        return "E — tidak terlihat"


# ==========================================================
# KLASIFIKASI ODEH
# ==========================================================

def odeh_class(v):

    if v >= 5.65:
        return "A — Mudah terlihat"

    elif v >= 2.0:
        return "B — Terlihat dengan alat"

    elif v >= -0.96:
        return "C — Hanya teleskop"

    else:
        return "D — Tidak terlihat"


# ==========================================================
# KRITERIA MABIMS
# ==========================================================

def cek_mabims_historis(
    tanggal,
    alt_bulan,
    elong_geo,
    umur_jam,
    EPS=1e-6,
):

    if tanggal.year >= 2022:

        alt_ok = (alt_bulan + EPS) >= 3.0
        elong_ok = (elong_geo + EPS) >= 6.4

        terpenuhi = alt_ok and elong_ok

        label = "Neo MABIMS (2022+)"

        umur_ok = True

    else:

        alt_ok = (alt_bulan + EPS) >= 2.0
        elong_ok = (elong_geo + EPS) >= 3.0
        umur_ok = (umur_jam + EPS) >= 8.0

        terpenuhi = (alt_ok and elong_ok) or (umur_ok and alt_ok)

        label = "MABIMS Lama (pre-2022)"

    return terpenuhi, alt_ok, elong_ok, umur_ok, label


# ==========================================================
# FUNGSI UTAMA HISAB
# ==========================================================

def hitung_awal_bulan_hijriah(
    tahun_hijriah,
    bulan_hijriah,
    ts,
    eph,
    topos,
    lokasi_geo,
):

    hijri_date = Hijri(tahun_hijriah, bulan_hijriah, 1)

    gregorian = hijri_date.to_gregorian()

    perkiraan = datetime(
        gregorian.year,
        gregorian.month,
        gregorian.day,
    ).date()

    print(f"Perkiraan awal bulan {tahun_hijriah}-{bulan_hijriah}: {perkiraan}")

    nm_utc, tgl_lokal_newmoon = cari_new_moon_terdekat(
        perkiraan,
        ts,
        eph,
    )

    nm_wib = nm_utc.astimezone(TZ_WIB)

    print(f"Ijtimak: {nm_wib.strftime('%d-%m-%Y %H:%M WIB')}")

    maghrib_nm = cari_waktu_maghrib(
        tgl_lokal_newmoon,
        ts,
        eph,
        topos,
    )

    nm_naive = to_utc_naive(nm_utc)

    if maghrib_nm and nm_naive < to_utc_naive(maghrib_nm):

        start_i = 0
        print("Ijtimak sebelum maghrib")

    else:

        start_i = 1
        print("Ijtimak setelah maghrib")

    for i in range(start_i, start_i + 3):

        tanggal_periksa = tgl_lokal_newmoon + timedelta(days=i)

        print(f"\nMemeriksa maghrib {tanggal_periksa}")

        maghrib_utc = cari_waktu_maghrib(
            tanggal_periksa,
            ts,
            eph,
            topos,
        )

        moonset_utc = cari_waktu_moonset(
            tanggal_periksa,
            ts,
            eph,
            topos,
        )

        best_utc = cari_best_time(
            maghrib_utc,
            moonset_utc,
        )

        (
            alt_bulan_ref,
            alt_matahari_ref,
            alt_bulan_air,
            alt_matahari_air,
            elong_top,
            jarak_bulan,
            elong_geo,
        ) = hitung_bulan_pada_waktu(
            maghrib_utc,
            ts,
            eph,
            lokasi_geo,
        )

        umur_jam = (
            to_utc_naive(maghrib_utc) - nm_naive
        ).total_seconds() / 3600

        mabims_ok, alt_ok, elong_ok, umur_ok, label = cek_mabims_historis(
            tanggal_periksa,
            alt_bulan_ref,
            elong_geo,
            umur_jam,
        )

        print(
            f"[MABIMS] alt={alt_bulan_ref:.2f}°, elong={elong_geo:.2f}°, umur={umur_jam:.1f} jam"
        )

        if mabims_ok:

            tanggal_1 = tanggal_periksa + timedelta(days=1)

            print(f"✅ Awal bulan = {tanggal_1}")

            return tanggal_1

    tanggal_istikmal = tgl_lokal_newmoon + timedelta(days=start_i + 3)

    print("⚠️ Istikmal")

    return tanggal_istikmal


# ==========================================================
# MAIN
# ==========================================================

def main():

    try:
        tahun = int(input("Masukkan tahun Hijriah: "))
    except ValueError:
        print("Input harus angka")
        return

    earth = eph["earth"]

    topos = wgs84.latlon(
        LATITUDE,
        LONGITUDE,
        elevation_m=ELEVATION,
    )

    lokasi_geo = earth + topos

    try:

        ramadan = hitung_awal_bulan_hijriah(
            tahun,
            9,
            ts,
            eph,
            topos,
            lokasi_geo,
        )

        syawal = hitung_awal_bulan_hijriah(
            tahun,
            10,
            ts,
            eph,
            topos,
            lokasi_geo,
        )

        print("\n=== HASIL ===")

        print(f"1 Ramadan {tahun} H: {ramadan}")
        print(f"1 Syawal {tahun} H: {syawal}")

    except Exception as e:

        print(f"Terjadi kesalahan: {e}")

        traceback.print_exc()


if __name__ == "__main__":
    main()
